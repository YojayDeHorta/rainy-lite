{
  "name": "asuka-desktop",
  "productName": "Asuka Desktop",
  "version": "0.1.0",
  "description": "Desktop AI companion for Windows.",
  "main": "app/main/main.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "backend": "python3 -m uvicorn backend.main:app --host 127.0.0.1 --port 8765",
    "backend:win": "python -m uvicorn backend.main:app --host 127.0.0.1 --port 8765",
    "build:backend": "powershell.exe -ExecutionPolicy Bypass -File scripts/build-backend.ps1",
    "dist:portable": "npm run build:backend && electron-builder --win portable",
    "dist:installer": "npm run build:backend && electron-builder --win nsis",
    "dist:win": "npm run build:backend && electron-builder --win nsis portable"
  },
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.asukadesktop.app",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "backend/**/*",
      "assets/**/*",
      "requirements.txt",
      "package.json",
      "!temp/**",
      "!data/**",
      "!dist/**",
      "!**/*.sqlite"
    ],
    "extraFiles": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "extraResources": [
      {
        "from": "dist/asuka-backend",
        "to": "backend/asuka-backend"
      },
      {
        "from": "assets/wakeword",
        "to": "assets/wakeword"
      }
    ],
    "asarUnpack": [
      "backend/**"
    ],
    "win": {
      "icon": "build/asuka.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "include": "build/installer.nsh",
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "build/asuka.ico",
      "uninstallerIcon": "build/asuka.ico",
      "installerHeaderIcon": "build/asuka.ico",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Asuka Desktop"
    }
  },
  "dependencies": {
    "discord-rpc": "^4.0.1"
  }
}
