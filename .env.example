# Rainy Lite local backend
RAINY_HOST=127.0.0.1
RAINY_PORT=8765

# local | gemini | groq | openai | ollama
AI_PROVIDER=local
AI_TEMPERATURE=0.8

# Gemini
GEMINI_KEY=
AI_MODEL=gemini-1.5-flash

# Groq chat + Whisper STT
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
STT_PROVIDER=groq
STT_LANGUAGE=es

# OpenAI-compatible APIs
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Ollama local
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# Spotify Web API
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Voice
TTS_VOICE=es-MX-DaliaNeural
TTS_RATE=+8%
TTS_PITCH=+20Hz
