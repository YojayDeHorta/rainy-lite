# Rainy Lite local backend
RAINY_HOST=127.0.0.1
RAINY_PORT=8765

# local | gemini | groq | openai | ollama
AI_PROVIDER=local
AI_TEMPERATURE=0.8

# Gemini
GEMINI_KEY=
AI_MODEL=gemini-1.5-flash

# Groq chat + Whisper STT
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
STT_PROVIDER=groq
STT_LANGUAGE=es

# OpenAI-compatible APIs
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Ollama local
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# Spotify Web API
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Voice
TTS_VOICE=es-MX-DaliaNeural
TTS_RATE=+8%
TTS_PITCH=+20Hz

# Wake word (OpenWakeWord, fase 1 keyword default)
WAKEWORD_ENABLED=0
# Modelos custom: prueba 0.35-0.5 si no dispara
WAKEWORD_THRESHOLD=0.55
WAKEWORD_COOLDOWN_S=2.5
# Debe coincidir con assets/wakeword/{nombre}_v0.1.onnx o {nombre}.onnx (ej. hey_asuka)
WAKEWORD_NAME=alexa
# Opcional: fuerza un archivo concreto
WAKEWORD_MODEL_PATH=
# Microfono solo para OpenWakeWord (Python/sounddevice). Vacio = predeterminado de Windows.
# Con auriculares Bluetooth suele ser el perfil Hands-Free y degrada el audio al abrir la app.
# Lista de IDs: GET http://127.0.0.1:8765/api/wakeword/input-devices (usa el campo id)
# Ejemplo: WAKEWORD_SOUND_DEVICE=4   o   WAKEWORD_SOUND_DEVICE=USB
WAKEWORD_SOUND_DEVICE=
