# Asuka Desktop local backend
RAINY_HOST=127.0.0.1
RAINY_PORT=8765

# Recommended for distributed app builds: proxy handles AI, STT, and Spotify server-side.
PROXY_URL=https://asuka-backend.yojay.space
PROXY_SECRET=

# Optional local-dev fallback. Leave PROXY_URL empty to use these directly from this machine.
# local | gemini | groq | openai | ollama
AI_PROVIDER=local
AI_TEMPERATURE=0.8
AI_MODEL=gemini-1.5-flash
GEMINI_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
STT_PROVIDER=groq
STT_LANGUAGE=es

# Voice (Edge TTS, always local)
TTS_VOICE=es-MX-DaliaNeural
TTS_RATE=+8%
TTS_PITCH=+20Hz
TTS_VOLUME=+0%

# temp/ cleanup for generated TTS/STT files
TEMP_FILE_MAX_AGE_MINUTES=45
TEMP_CLEANUP_INTERVAL_MINUTES=10

# Wake word (OpenWakeWord)
WAKEWORD_ENABLED=0
WAKEWORD_THRESHOLD=0.55
WAKEWORD_COOLDOWN_S=2.5
# Must match assets/wakeword/{name}_v0.1.onnx or {name}.onnx unless WAKEWORD_MODEL_PATH is set.
WAKEWORD_NAME=alexa
WAKEWORD_MODEL_PATH=
# Empty = system default input. Use /api/wakeword/input-devices to list IDs.
WAKEWORD_SOUND_DEVICE=
